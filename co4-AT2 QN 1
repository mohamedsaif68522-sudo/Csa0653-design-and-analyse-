Python Code (Warehouse Delivery Route Optimization using Kruskal)
# Warehouse Delivery Route Optimization
# Greedy Strategy - Kruskal's Algorithm

class DisjointSet:
    def __init__(self, n):
        self.parent = [i for i in range(n)]

    def find(self, x):
        if self.parent[x] != x:
            self.parent[x] = self.find(self.parent[x])
        return self.parent[x]

    def union(self, a, b):
        root_a = self.find(a)
        root_b = self.find(b)

        if root_a != root_b:
            self.parent[root_b] = root_a
            return True

        return False


def optimize_route(locations, routes):
    # Sort routes by delivery cost
    routes.sort(key=lambda x: x[2])

    ds = DisjointSet(locations)

    total_cost = 0
    selected_routes = []

    for source, destination, cost in routes:
        # Add route if it does not form a cycle
        if ds.union(source, destination):
            selected_routes.append((source, destination, cost))
            total_cost += cost

    return selected_routes, total_cost


